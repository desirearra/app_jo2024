    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^7.0.3",
    "express-rate-limit": "^7.5.0",
    "swagger-jsdoc": "^6.2.8",
    "zod": "^3.25.28",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
