// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum OffreType {
  SOLO    // 1 personne
  DUO     // 2 personnes
  FAMILLE // 4 personnes
}

enum CommandeStatut {
  EN_ATTENTE
  PAYEE
  ANNULEE
  REMBOURSEE
}

model User {
  id         String     @id @default(uuid())
  email      String     @unique
  password   String
  nom        String
  prenom     String
  role       UserRole   @default(USER)
  cle1       String?    // Clé chiffrée ou hash
  commandes  Commande[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@map("utilisateurs")
}

model Offre {
  id          String     @id @default(uuid())
  nom         String
  description String
  prix        Decimal    @db.Decimal(10, 2)
  type        OffreType
  places      Int
  actif       Boolean    @default(true)
  commandes   Commande[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("offres")
}

model Commande {
  id              String          @id @default(uuid())
  utilisateur     User            @relation(fields: [utilisateurId], references: [id])
  utilisateurId   String
  offre           Offre           @relation(fields: [offreId], references: [id])
  offreId         String
  statut          CommandeStatut  @default(EN_ATTENTE)
  typeTransaction String?
  idTransaction   String?
  montantTotal    Decimal         @db.Decimal(10, 2)
  cle2            String?
  billets         Billet[]
  dateCommande    DateTime        @default(now())

  @@index([utilisateurId])
  @@index([offreId])
  @@map("commandes")
}

model Billet {
  id             String    @id @default(uuid())
  commande       Commande  @relation(fields: [commandeId], references: [id])
  commandeId     String
  qrCode         String    @unique
  utilise        Boolean   @default(false)
  dateUtilisation DateTime?
  cleFinale      String?

  @@map("billets")
}
