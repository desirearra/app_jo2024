{
  "openapi": "3.0.3",
  "info": {
    "title": "API E-billets JO 2024",
    "version": "1.0.0",
    "description": "Documentation interactive de l'API e-billets JO 2024 (auth, users, offers)"
  },
  "servers": [{ "url": "http://localhost:4000/api", "description": "Local dev" }],
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Login utilisateur",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token JWT retourné",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/auth/register": {
      "post": {
        "summary": "Inscription utilisateur",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "firstName": { "type": "string" },
                  "lastName": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                },
                "required": ["firstName", "lastName", "email", "password"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Utilisateur créé" },
          "400": { "description": "Erreur de validation" }
        }
      }
    },
    "/auth/2fa/verify": {
      "post": {
        "summary": "Vérifier le code 2FA (admin)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "code": { "type": "string" }
                },
                "required": ["email", "code"]
              },
              "example": {
                "email": "admin@example.com",
                "code": "123456"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "2FA vérifié, JWT retourné",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": { "description": "Code 2FA invalide ou expiré" }
        }
      }
    },
    "/users": {
      "get": {
        "summary": "Lister tous les utilisateurs (admin)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Liste des utilisateurs" },
          "403": { "description": "Forbidden" }
        }
      }
    },
    "/offers": {
      "get": {
        "summary": "Lister toutes les offres",
        "responses": {
          "200": { "description": "Liste des offres" }
        }
      },
      "post": {
        "summary": "Créer une offre (admin)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" },
                  "price": { "type": "string" },
                  "type": { "type": "string" },
                  "seats": { "type": "integer" }
                },
                "required": ["name", "description", "price", "type", "seats"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Offre créée" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/tickets": {
      "get": {
        "summary": "List all tickets (admin only)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "List of tickets",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Ticket" } }
              }
            }
          },
          "403": { "description": "Forbidden" }
        }
      },
      "post": {
        "summary": "Create a ticket (admin only)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TicketCreate" },
              "example": {
                "userId": "uuid-user",
                "offerId": "uuid-offer",
                "finalKey": "QR123456789"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Ticket created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Ticket" }
              }
            }
          },
          "400": { "description": "Invalid ticket data" },
          "403": { "description": "Forbidden" }
        }
      }
    },
    "/tickets/{id}": {
      "get": {
        "summary": "Get a ticket by id (admin only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Ticket found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Ticket" }
              }
            }
          },
          "404": { "description": "Ticket not found" },
          "403": { "description": "Forbidden" }
        }
      },
      "put": {
        "summary": "Update a ticket (admin only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TicketUpdate" },
              "example": { "status": "USED" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ticket updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Ticket" }
              }
            }
          },
          "400": { "description": "Invalid ticket update data" },
          "404": { "description": "Ticket not found" },
          "403": { "description": "Forbidden" }
        }
      },
      "delete": {
        "summary": "Soft delete a ticket (admin only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Ticket deleted (soft)" },
          "404": { "description": "Ticket not found" },
          "403": { "description": "Forbidden" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Ticket": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "userId": { "type": "string", "format": "uuid" },
          "offerId": { "type": "string", "format": "uuid" },
          "finalKey": { "type": "string" },
          "status": { "type": "string", "enum": ["ACTIVE", "USED", "CANCELLED"] },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "isDeleted": { "type": "boolean" }
        },
        "required": [
          "id",
          "userId",
          "offerId",
          "finalKey",
          "status",
          "createdAt",
          "updatedAt",
          "isDeleted"
        ]
      },
      "TicketCreate": {
        "type": "object",
        "properties": {
          "userId": { "type": "string", "format": "uuid" },
          "offerId": { "type": "string", "format": "uuid" },
          "finalKey": { "type": "string" },
          "status": { "type": "string", "enum": ["ACTIVE", "USED", "CANCELLED"] }
        },
        "required": ["userId", "offerId", "finalKey"]
      },
      "TicketUpdate": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["ACTIVE", "USED", "CANCELLED"] },
          "isDeleted": { "type": "boolean" }
        }
      }
    }
  }
}
